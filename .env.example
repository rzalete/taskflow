APP_NAME=Taskflow
ENVIRONMENT=development
SECRET_KEY=dev-only-secret-change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256
DATABASE_URL=sqlite:///./taskflow.db
CORS_ORIGINS=http://localhost:5173

# Database connection (optional). Defaults to local SQLite if unset.
# For PostgreSQL use the psycopg 3 scheme below; a host-provided
# postgres:// or postgresql:// URL is auto-normalized to it.
# DATABASE_URL=postgresql+psycopg://taskflow:taskflow@localhost:5432/taskflow
